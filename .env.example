# Slack App Configuration
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret

# Claude Code Configuration
# Authentication: Choose ONE of the following methods:
#
# Method 1 (Recommended): Claude.ai subscription (OAuth)
#   Run "claude login" in your terminal first. Leave ANTHROPIC_API_KEY commented out.
#
# Method 2: Anthropic API key
#   Uncomment and set your API key below.
#   IMPORTANT: Do NOT leave as empty string (ANTHROPIC_API_KEY=). Either set a
#   valid key or keep it commented out. An empty value causes auth failure.
#
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Working Directory Configuration
# Base directory for relative paths
# If set, you can use "cwd project-name" instead of full paths
# Example: BASE_DIRECTORY=/Users/username/Code/
BASE_DIRECTORY=

# Optional: Use third-party providers
# CLAUDE_CODE_USE_BEDROCK=1
# CLAUDE_CODE_USE_VERTEX=1

# Multi-instance Configuration
# Set a unique name per instance (used in logs and temp file prefixes)
# INSTANCE_NAME=team-a
# Path to a custom MCP server configuration file
# MCP_CONFIG_PATH=./mcp-servers-team-a.json

# Development
# DEBUG=true